# Runtime bridge files (queue/ack spool shared by executor + mqbridge.lua)
/.bridge/
# Runtime player-state file (written by playerwatch.lua, read by brain/shadow.js)
/.player/

# config.json IS committed (required by the launchers; shared value works on both machines
# when brain.executorHost = the box's LAN IP). config.example.json stays as a template.

# E3Next/MacroQuest install (we run MQ from here on both machines).
# Ignore the binaries/vendor runtime, but TRACK the e3 config INIs (per-character client configs +
# shared macro settings) so they're maintained here and synced over git.
# NOTE: MQ rewrites these INIs at runtime — treat git as the canonical store: edit -> push -> pull +
# reload; capture in-game tweaks by committing them on the machine that made them. Binaries are NOT
# synced — each machine keeps its own copy of the install; only config/ travels over git.
# Our MQ Lua source of truth stays in /mqbridge/*.lua (deploy into the install with deploy-lua.ps1).
/tools/E3Next/*
# Track ONLY the e3 config subtrees — NOT the whole MQ config folder. The config root holds login
# CREDENTIALS (MQ2AutoLogin.ini, login.db*) and per-machine UI/plugin state that must never be committed.
!/tools/E3Next/config/
/tools/E3Next/config/*
!/tools/E3Next/config/e3 Bot Inis/
!/tools/E3Next/config/e3 Macro Inis/
# ...and drop runtime/churny bits within those (rewritten every session / machine-specific):
/tools/E3Next/config/**/*_UI.ini
/tools/E3Next/config/**/*.db
/tools/E3Next/config/**/*.reg
/tools/E3Next/config/**/SharedData/

# Node
node_modules/
npm-debug.log*

# Logs / scratch
*.log

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store
